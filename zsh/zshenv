# path {{{
# prevent from duplicate records in path
typeset -U path
# }}}

# python {{{

export VIRTUALENV_SYSTEM_SITE_PACKAGES=true

# }}}

# podman, helm, everything that is related to clouds. {{{

export AWS_VAULT_BACKEND=file

if [ -f "$HOME/.kube/k3s.yaml" ]; then
	export KUBECONFIG="$HOME/.kube/k3s.yaml"
fi

# }}}

# homebrew {{{

# ensure homebrew is on PATH for non-login / non-interactive zsh too
# (login-only ~/.zprofile is too late for GUI apps and `sh -c` consumers).
if [[ "$OSTYPE" == "darwin"* ]]; then
	if [ -x /opt/homebrew/bin/brew ]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	elif [ -x /usr/local/bin/brew ]; then
		eval "$(/usr/local/bin/brew shellenv)"
	fi

	# require explicit `brew trust` for non-official taps
	export HOMEBREW_REQUIRE_TAP_TRUST=1
fi

# }}}

# home-made paths {{{

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ]; then
	path+=("$HOME/bin")
fi

# set PATH so it includes user's local private bin if it exists
if [ -d "$HOME/.local/bin" ]; then
	path+=("$HOME/.local/bin")
fi

# set PATH so it includes cargo's bin if it exists
if [ -d "$HOME/.cargo/bin" ]; then
    path+=("$HOME/.cargo/bin")
fi


# }}}

# languages {{{

# you may need to manually set your language environment
export LANG="en_US.UTF-8"
export LANGUAGE="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# }}}

# editors and terminals {{{

EDITOR="$(command -v nvim)"
export EDITOR

SUDO_EDITOR="$(command -v nvim)"
export SUDO_EDITOR

TERM="xterm-256color"
export TERM

DISABLE_AUTO_TITLE='true'
export DISABLE_AUTO_TITLE

# }}}

# path {{{

export PATH

# }}}
