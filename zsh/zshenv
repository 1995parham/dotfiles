# path {{{
# prevent from duplicate records in path
typeset -U path
# }}}

# python {{{

export VIRTUALENV_SYSTEM_SITE_PACKAGES=true

# }}}

# podman, helm, everything that is related to clouds. {{{

export AWS_VAULT_BACKEND=file

if [ -f "$HOME/.kube/k3s.yaml" ]; then
	export KUBECONFIG="$HOME/.kube/k3s.yaml"
fi

# }}}

# homebrew {{{

# ensure homebrew is on PATH for non-login / non-interactive zsh too
# (login-only ~/.zprofile is too late for GUI apps and `sh -c` consumers).
if [[ "$OSTYPE" == "darwin"* ]]; then
	if [ -x /opt/homebrew/bin/brew ]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	elif [ -x /usr/local/bin/brew ]; then
		eval "$(/usr/local/bin/brew shellenv)"
	fi

	# require explicit `brew trust` for non-official taps
	export HOMEBREW_REQUIRE_TAP_TRUST=1
fi

# }}}

# home-made paths {{{

# add well-known user bin dirs, but only when they exist.
# the (N-/) glob qualifier keeps an entry only if it resolves to a real
# directory, so no per-path `[ -d ... ]` guard is needed.
path+=(
	$HOME/bin(N-/)
	$HOME/.local/bin(N-/)
	$HOME/.cargo/bin(N-/)
	$HOME/.pixi/bin(N-/)
)


# }}}

# languages {{{

# you may need to manually set your language environment.
# avoid LC_ALL here: it hard-overrides every locale category and breaks on
# hosts where en_US.UTF-8 isn't generated. LANG + LC_CTYPE is enough.
export LANG="en_US.UTF-8"
export LANGUAGE="en_US.UTF-8"
export LC_CTYPE="en_US.UTF-8"

# }}}

# editors and terminals {{{

EDITOR="$(command -v nvim)"
export EDITOR

SUDO_EDITOR="$(command -v nvim)"
export SUDO_EDITOR

# let the terminal own $TERM (modern terminals/tmux advertise truecolor,
# undercurl, etc.); only provide a fallback when it is genuinely unset.
[[ -z "$TERM" ]] && export TERM=xterm-256color

DISABLE_AUTO_TITLE='true'
export DISABLE_AUTO_TITLE

# }}}

# path {{{

export PATH

# }}}
